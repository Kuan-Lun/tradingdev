#!/usr/bin/env bash
# Block direct commits to main. Use scripts/git-flow-commit.sh instead.
branch=$(git symbolic-ref --short HEAD 2>/dev/null)
if [ "$branch" = "main" ]; then
    echo "ERROR: direct commits to main are not allowed." >&2
    echo "Use: scripts/git-flow-commit.sh <branch-suffix> <commit-msg> [files...]" >&2
    exit 1
fi
